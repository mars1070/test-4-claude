---
import Layout from '../layouts/Layout.astro';
const posts = [
  { slug: 'hello-world', title: 'Hello World', date: '2024-01-15', excerpt: 'Welcome to test-4-claude, your new Astro blog.' },
  { slug: 'getting-started', title: 'Getting Started with Astro', date: '2024-01-10', excerpt: 'Astro is a fast, modern static site builder.' },
];
---
<Layout title="test-4-claude — Blog">
  <main style="max-width:720px;margin:0 auto;padding:60px 24px">
    <header style="margin-bottom:48px">
      <h1 style="font-size:2rem;font-weight:800;letter-spacing:-1px;color:#e2e2f0">test-4-claude</h1>
      <p style="color:#6b6b8a;margin-top:8px">A fast blog powered by Astro</p>
    </header>
    <div>
      {posts.map(post => (
        <article style="border-bottom:1px solid #1c1c2e;padding:28px 0">
          <h2 style="font-size:1.25rem;font-weight:700;margin-bottom:6px">
            <a href={'/blog/' + post.slug} style="color:#e2e2f0">{post.title}</a>
          </h2>
          <p style="color:#6b6b8a;font-size:0.9rem;margin-bottom:8px">{post.date}</p>
          <p style="color:#a8a8c8">{post.excerpt}</p>
        </article>
      ))}
    </div>
  </main>
</Layout>
