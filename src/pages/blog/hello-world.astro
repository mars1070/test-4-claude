---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Hello World — test-4-claude">
  <main style="max-width:720px;margin:0 auto;padding:60px 24px">
    <a href="/" style="color:#6b6b8a;font-size:0.9rem">← Back</a>
    <h1 style="font-size:2rem;font-weight:800;margin:24px 0 8px;letter-spacing:-1px">Hello World</h1>
    <p style="color:#6b6b8a;margin-bottom:32px">January 15, 2024</p>
    <div style="color:#a8a8c8;line-height:1.8">
      <p>Welcome to <strong style="color:#e2e2f0">test-4-claude</strong>, your new Astro blog deployed with Deploo.</p>
      <p style="margin-top:16px">Edit this file at <code style="background:#1c1c2e;padding:2px 6px;border-radius:4px">src/pages/blog/hello-world.astro</code> to get started.</p>
    </div>
  </main>
</Layout>
